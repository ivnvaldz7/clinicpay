PORT=4000
MONGODB_URI=mongodb://localhost:27017/clinicpay

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

CLIENT_ORIGIN=http://localhost:5173
COOKIE_SAME_SITE=strict
COOKIE_SECURE=false

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...

RESEND_API_KEY=re_...
EMAIL_FROM=ClinicPay <noreply@clinicpay.app>

# Cron schedule for overdue reminders (default: 08:00 every day)
OVERDUE_CRON_SCHEDULE=0 8 * * *
